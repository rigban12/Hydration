<!DOCTYPE html>

<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Allianz Wellness Bingo</title>

<link rel="preconnect" href=https://fonts.googleapis.com>

<link rel="preconnect" href=https://fonts.gstatic.com crossorigin>

<link href=https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=DM+Sans:wght@400;500&display=swap rel="stylesheet">

<link href=https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.5.0/dist/tabler-icons.min.css rel="stylesheet">

<style>

:root {

  --cream: #F6F1E6;

  --paper: #FBF8F1;

  --ink: #1E2A22;

  --ink-soft: #5D6A60;

  --line: rgba(30,42,34,0.12);

  --leaf: #4F7A5A;

  --leaf-soft: #E5EFE2;

  --amber: #C18636;

  --amber-soft: #F6E8CC;

  --terracotta: #B5614A;

  --terracotta-soft: #F1DDD3;

}

 

* { box-sizing: border-box; margin: 0; padding: 0; }

 

html, body { color: var(--ink); font-family: 'DM Sans', system-ui, sans-serif; min-height: 100%; -webkit-font-smoothing: antialiased; }

body { background-image: url('data:image/jpeg;base64,'); background-size: cover; background-position: center; background-attachment: fixed; background-repeat: no-repeat; position: relative; }

body::before { content: ''; position: fixed; inset: 0; background: rgba(214, 230, 245, 0.45); z-index: 0; pointer-events: none; }

.page { position: relative; z-index: 1; }

 

.page { max-width: 780px; margin: 0 auto; padding: 44px 20px 60px; }

 

.header { text-align: center; margin-bottom: 32px; }

 

.eyebrow { font-size: 11px; font-weight: 500; letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-soft); margin-bottom: 14px; }

 

.title { font-family: 'Fraunces', serif; font-size: clamp(40px, 6.5vw, 60px); font-weight: 400; font-variation-settings: 'opsz' 144; line-height: 1; letter-spacing: -0.025em; }

.title em { font-style: italic; color: var(--leaf); }

 

.intro { font-size: 15px; color: var(--ink-soft); margin: 16px auto 0; max-width: 480px; line-height: 1.6; }

 

.grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px; }

 

.cell { background: var(--paper); border: 1px solid var(--line); border-radius: 12px; aspect-ratio: 1; padding: 10px 9px 11px; display: flex; flex-direction: column; justify-content: space-between; cursor: pointer; position: relative; transition: transform 0.15s ease, background 0.2s ease, border-color 0.2s ease; user-select: none; overflow: hidden; }

.cell:hover { transform: translateY(-2px); border-color: var(--ink-soft); }

.cell:active { transform: translateY(0); }

 

.cell .num { font-family: 'Fraunces', serif; font-size: 11px; font-weight: 500; color: var(--ink-soft); letter-spacing: 0.08em; }

 

.cell .icon-wrap { display: flex; justify-content: center; align-items: center; flex: 1; }

.cell .icon-wrap i { font-size: 28px; color: var(--ink-soft); line-height: 1; transition: color 0.2s ease, transform 0.25s ease; }

 

.cell .label { font-size: 11.5px; line-height: 1.32; font-weight: 500; color: var(--ink); text-align: center; }

 

.cell .check { position: absolute; top: 9px; right: 9px; width: 16px; height: 16px; border-radius: 50%; border: 1px solid var(--line); display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.2s ease, transform 0.25s cubic-bezier(0.3, 1.4, 0.5, 1); transform: scale(0.6); }

 

.cell.done { background: var(--leaf-soft); border-color: var(--leaf); }

.cell.done .label, .cell.done .num { color: var(--leaf); }

.cell.done .icon-wrap i { color: var(--leaf); transform: scale(1.08); }

.cell.done .check { opacity: 1; background: var(--leaf); border-color: var(--leaf); transform: scale(1); }

.cell.done .check::after { content: ''; width: 7px; height: 4px; border-left: 1.5px solid var(--cream); border-bottom: 1.5px solid var(--cream); transform: rotate(-45deg) translate(0.5px, -1px); }

 

.cell.free { background: var(--terracotta-soft); border-color: var(--terracotta); cursor: default; }

.cell.free:hover { transform: none; border-color: var(--terracotta); }

.cell.free .num, .cell.free .label { color: var(--terracotta); }

.cell.free .icon-wrap i { color: var(--terracotta); font-size: 32px; }

.cell.free .label { font-family: 'Fraunces', serif; font-style: italic; font-size: 12.5px; font-weight: 500; line-height: 1.25; }

 

.cell.in-line { box-shadow: 0 0 0 2px var(--amber); }

.cell.in-line.done { background: var(--amber-soft); border-color: var(--amber); }

.cell.in-line.done .label, .cell.in-line.done .num { color: var(--amber); }

.cell.in-line.done .icon-wrap i { color: var(--amber); }

.cell.in-line.done .check { background: var(--amber); border-color: var(--amber); }

 

.footer { display: flex; align-items: center; justify-content: space-between; margin-top: 18px; padding: 18px 22px; background: var(--paper); border: 1px solid var(--line); border-radius: 14px; }

.stats { display: flex; gap: 28px; }

.stat .num { font-family: 'Fraunces', serif; font-size: 24px; font-weight: 500; color: var(--ink); line-height: 1; }

.stat .lbl { font-size: 10.5px; color: var(--ink-soft); letter-spacing: 0.12em; text-transform: uppercase; margin-top: 5px; }

 

.actions { display: flex; gap: 8px; }

.btn { background: transparent; border: 1px solid var(--line); color: var(--ink); padding: 8px 16px; border-radius: 999px; font-family: inherit; font-size: 13px; font-weight: 500; cursor: pointer; transition: background 0.15s ease, border-color 0.15s ease; }

.btn:hover { background: var(--cream); border-color: var(--ink-soft); }

.btn.primary { background: var(--ink); color: var(--cream); border-color: var(--ink); }

.btn.primary:hover { opacity: 0.88; background: var(--ink); }

 

.tagline { text-align: center; margin-top: 28px; font-size: 12px; color: var(--ink-soft); letter-spacing: 0.04em; }

 

.celebration { position: fixed; inset: 0; background: rgba(30,42,34,0.55); display: none; align-items: center; justify-content: center; z-index: 100; animation: fadeIn 0.35s ease; padding: 20px; }

.celebration.show { display: flex; }

.celebration-box { background: var(--paper); border-radius: 22px; padding: 48px 56px; text-align: center; position: relative; animation: popIn 0.5s cubic-bezier(0.3, 1.4, 0.5, 1); max-width: 440px; }

.celebration-box h2 { font-family: 'Fraunces', serif; font-size: 80px; font-weight: 400; letter-spacing: -0.04em; color: var(--leaf); line-height: 0.95; }

.celebration-box h2 em { font-style: italic; color: var(--amber); }

.celebration-box p { margin: 18px 0 26px; color: var(--ink-soft); font-size: 15px; line-height: 1.5; }

 

@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

@keyframes popIn { 0% { transform: scale(0.7); opacity: 0; } 100% { transform: scale(1); opacity: 1; } }

 

.confetti-dot { position: absolute; width: 8px; height: 8px; border-radius: 50%; pointer-events: none; }

 

@media (max-width: 620px) {

  .page { padding: 28px 14px 50px; }

  .cell { padding: 8px 6px 9px; }

  .cell .label { font-size: 10.5px; line-height: 1.25; }

  .cell .num { font-size: 10px; }

  .cell .icon-wrap i { font-size: 22px; }

  .footer { flex-direction: column; gap: 16px; align-items: stretch; }

  .stats { justify-content: space-around; }

  .actions { justify-content: center; }

  .celebration-box { padding: 36px 28px; }

  .celebration-box h2 { font-size: 60px; }

}

</style>

</head>

<body>

<div class="page">

  <header class="header">

    <h1 class="title">Allianz Wellness <em>Bingo</em></h1>

    <p class="intro">Complete the activities. Tap each square as you finish. Make a line of five — across, down, or diagonally — to call bingo. The centre square is on the house.</p>

  </header>

 

  <div class="grid" id="grid"></div>

 

  <div class="footer">

    <div class="stats">

      <div class="stat"><div class="num" id="done">1</div><div class="lbl">Done</div></div>

      <div class="stat"><div class="num" id="lines">0</div><div class="lbl">Bingo lines</div></div>

      <div class="stat"><div class="num" id="pct">4%</div><div class="lbl">Complete</div></div>

    </div>

    <div class="actions">

      <button class="btn" id="reset">Reset</button>

    </div>

  </div>

 

  <p class="tagline">Move a little. Breathe a little. Connect a lot.</p>

</div>

 

<div class="celebration" id="celebration">

  <div class="celebration-box">

    <h2>B<em>i</em>ngo!</h2>

    <p>You've made your first line. Drop "BINGO" in the call chat and keep going for a full house.</p>

    <button class="btn primary" onclick="document.getElementById('celebration').classList.remove('show')">Keep playing</button>

  </div>

</div>

 

<script>

const activities = [

  { label: '10 slow deep breaths', icon: 'ti-lungs' },

  { label: 'Roll your neck 5x each way', icon: 'ti-rotate-360' },

  { label: 'Stand up & stretch tall', icon: 'ti-arrow-bar-to-up' },

  { label: 'Drink a full glass of water', icon: 'ti-glass-full' },

  { label: '20-20-20 eye break', icon: 'ti-eye' },

  { label: 'Compliment someone on the call', icon: 'ti-thumb-up' },

  { label: 'Shoulder rolls x10', icon: 'ti-refresh' },

  { label: 'Box breathing for 30 sec', icon: 'ti-square' },

  { label: 'Wrist circles x10 each way', icon: 'ti-rotate' },

  { label: 'Desk push-ups x5', icon: 'ti-barbell' },

  { label: 'Look out a window 30 sec', icon: 'ti-window' },

  { label: 'Post a gratitude in chat', icon: 'ti-heart' },

  { label: 'Seated toe touches x5', icon: 'ti-arrow-down' },

  { label: 'Wave to someone on screen', icon: 'ti-hand-stop' },

  { label: 'Sit up tall for 30 sec', icon: 'ti-armchair-2' },

  { label: 'Calf raises x15', icon: 'ti-stairs-up' },

  { label: 'Share a wellness tip in chat', icon: 'ti-bulb' },

  { label: 'Palm your eyes for 20 sec', icon: 'ti-eye-off' },

  { label: '10 jumping jacks or marches', icon: 'ti-run' },

  { label: 'Tense & release shoulders', icon: 'ti-activity' },

  { label: 'Smile wide at the camera', icon: 'ti-mood-smile' },

  { label: 'Share a healthy snack in chat', icon: 'ti-apple' },

  { label: '1-minute mini-meditation', icon: 'ti-flower' },

  { label: 'Happy dance for 10 sec', icon: 'ti-music' }

];

 

const FREE_INDEX = 12;

let order = [];

const done = new Set();

let previousLineCount = 0;

 

function shuffle(arr) {

  const a = [...arr];

  for (let i = a.length - 1; i > 0; i--) {

    const j = Math.floor(Math.random() * (i + 1));

    [a[i], a[j]] = [a[j], a[i]];

  }

  return a;

}

 

function buildOrder() {

  const shuffled = shuffle(activities);

  order = [];

  let idx = 0;

  for (let i = 0; i < 25; i++) {

    if (i === FREE_INDEX) order.push(null);

    else { order.push(shuffled[idx]); idx++; }

  }

}

 

function render() {

  const grid = document.getElementById('grid');

  grid.innerHTML = '';

  order.forEach((item, i) => {

    const cell = document.createElement('div');

    if (item === null) {

      cell.className = 'cell free';

      cell.innerHTML =

        '<div class="num">FREE</div>' +

        '<div class="icon-wrap"><i class="ti ti-star" aria-hidden="true"></i></div>' +

        '<div class="label">You showed up. That counts.</div>';

    } else {

      cell.className = 'cell' + (done.has(i) ? ' done' : '');

      cell.innerHTML =

        '<div class="num">' + String(i + 1).padStart(2, '0') + '</div>' +

        '<div class="check"></div>' +

        '<div class="icon-wrap"><i class="ti ' + item.icon + '" aria-hidden="true"></i></div>' +

        '<div class="label">' + item.label + '</div>';

      cell.addEventListener('click', () => toggle(i));

    }

    grid.appendChild(cell);

  });

  updateStats();

}

 

function toggle(i) {

  if (done.has(i)) done.delete(i); else done.add(i);

  render();

}

 

function getLines() {

  const lines = [];

  for (let r = 0; r < 5; r++) lines.push([0,1,2,3,4].map(c => r*5+c));

  for (let c = 0; c < 5; c++) lines.push([0,1,2,3,4].map(r => r*5+c));

  lines.push([0,6,12,18,24]);

  lines.push([4,8,12,16,20]);

  return lines;

}

 

function isCellDone(i) { return i === FREE_INDEX || done.has(i); }

 

function updateStats() {

  const cells = document.querySelectorAll('.cell');

  let lineCount = 0;

  const inLine = new Set();

  getLines().forEach(line => {

    if (line.every(isCellDone)) {

      lineCount++;

      line.forEach(i => inLine.add(i));

    }

  });

  inLine.forEach(i => cells[i] && cells[i].classList.add('in-line'));

  const total = done.size + 1;

  document.getElementById('done').textContent = total;

  document.getElementById('lines').textContent = lineCount;

  document.getElementById('pct').textContent = Math.round(total / 25 * 100) + '%';

  if (lineCount > previousLineCount && previousLineCount === 0) celebrate();

  previousLineCount = lineCount;

}

 

function celebrate() {

  const cel = document.getElementById('celebration');

  cel.classList.add('show');

  spawnConfetti();

}

 

function spawnConfetti() {

  const colors = ['#4F7A5A','#C18636','#B5614A','#1E2A22'];

  const box = document.querySelector('.celebration-box');

  for (let i = 0; i < 32; i++) {

    const dot = document.createElement('div');

    dot.className = 'confetti-dot';

    dot.style.background = colors[i % colors.length];

    const x = (Math.random() - 0.5) * 320;

    const y = (Math.random() - 0.5) * 220;

    dot.style.left = '50%';

    dot.style.top = '50%';

    dot.style.transform = 'translate(' + x + 'px,' + y + 'px) scale(0)';

    dot.style.opacity = '0';

    dot.style.transition = 'transform 1s cubic-bezier(0.2,0.8,0.2,1), opacity 1s ease';

    box.appendChild(dot);

    requestAnimationFrame(() => {

      dot.style.opacity = '1';

      dot.style.transform = 'translate(' + (x * 1.8) + 'px,' + (y * 1.8 + 100) + 'px) scale(1)';

    });

    setTimeout(() => dot.remove(), 1300);

  }

}

 

document.getElementById('celebration').addEventListener('click', (e) => {

  if (e.target.id === 'celebration') e.target.classList.remove('show');

});

 

document.getElementById('reset').addEventListener('click', () => {

  done.clear();

  previousLineCount = 0;

  render();

});

 

buildOrder();

render();

</script>

</body>

</html>
